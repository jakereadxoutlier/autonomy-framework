{
  "rules": [
    { "match": { "source": "stripe", "type": "payment.*" }, "priority": 0, "reason": "Payment events need immediate attention" },
    { "match": { "source": "github", "type": "push" }, "priority": 1, "reason": "Code pushes" },
    { "match": { "source": "email" }, "priority": 1, "reason": "Incoming emails" },
    { "match": { "source": "cron", "type": "health_check" }, "priority": 2, "reason": "Routine health checks" },
    { "match": { "source": "fs", "type": "file_change" }, "priority": 3, "reason": "File system changes" },
    { "match": { "type": "*" }, "priority": 4, "reason": "Default: log everything" }
  ]
}
